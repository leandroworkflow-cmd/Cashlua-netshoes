<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --amarelo: #FFD600;
    --amarelo-escuro: #F5C000;
    --preto: #111111;
    --cinza-escuro: #1a1a1a;
    --cinza: #2e2e2e;
    --branco: #ffffff;
    --verde: #00C853;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--preto);
    color: var(--branco);
    overflow-x: hidden;
  }

  /* ── MODAL ── */
  #modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,.82);
    display: flex; align-items: center; justify-content: center;
    z-index: 9999;
    backdrop-filter: blur(6px);
    animation: fadeIn .4s ease;
  }
  @keyframes fadeIn { from{opacity:0} to{opacity:1} }

  #modal {
    background: var(--cinza-escuro);
    border: 2px solid var(--amarelo);
    border-radius: 20px;
    max-width: 480px;
    width: 90%;
    padding: 40px 36px 32px;
    text-align: center;
    position: relative;
    animation: slideUp .45s cubic-bezier(.22,1,.36,1);
  }
  @keyframes slideUp { from{transform:translateY(60px);opacity:0} to{transform:translateY(0);opacity:1} }

  #modal .modal-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.8rem;
    letter-spacing: 2px;
    color: var(--amarelo);
    line-height: 1;
    margin-bottom: 4px;
  }
  #modal .modal-logo span { color: var(--branco); }

  #modal .modal-badge {
    display: inline-block;
    background: var(--amarelo);
    color: var(--preto);
    font-size: .7rem;
    font-weight: 900;
    letter-spacing: 2px;
    padding: 3px 12px;
    border-radius: 30px;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  #modal h2 {
    font-size: 1.25rem;
    font-weight: 800;
    margin-bottom: 14px;
    line-height: 1.4;
  }
  #modal h2 span { color: var(--amarelo); }

  #modal p {
    font-size: .92rem;
    color: #ccc;
    line-height: 1.7;
    margin-bottom: 10px;
  }

  #modal .modal-highlight {
    background: rgba(255,214,0,.1);
    border-left: 3px solid var(--amarelo);
    border-radius: 8px;
    padding: 12px 16px;
    margin: 16px 0;
    font-size: .88rem;
    color: #e8e8e8;
    text-align: left;
  }
  #modal .modal-highlight strong { color: var(--amarelo); }

  #modal-btn {
    background: var(--amarelo);
    color: var(--preto);
    border: none;
    padding: 14px 36px;
    border-radius: 50px;
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    font-weight: 900;
    cursor: pointer;
    letter-spacing: .5px;
    transition: transform .15s, box-shadow .15s;
    margin-top: 8px;
    width: 100%;
  }
  #modal-btn:hover {
    transform: scale(1.03);
    box-shadow: 0 6px 24px rgba(255,214,0,.35);
  }

  #modal-close {
    position: absolute;
    top: 14px; right: 18px;
    background: none; border: none;
    color: #666; font-size: 1.4rem;
    cursor: pointer;
    transition: color .2s;
  }
  #modal-close:hover { color: var(--amarelo); }

  /* ── HEADER ── */
  header {
    background: var(--amarelo);
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 16px rgba(255,214,0,.3);
  }

  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    color: var(--preto);
    letter-spacing: 2px;
    line-height: 1;
    text-decoration: none;
  }
  .logo em { color: #333; font-style: normal; }

  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: .82rem;
    font-weight: 700;
    color: var(--preto);
  }
  .header-right .parceira {
    background: var(--preto);
    color: var(--amarelo);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: .72rem;
    letter-spacing: 1px;
  }

  /* ── HERO BANNER ── */
  .hero {
    position: relative;
    background: linear-gradient(135deg, #1a1a1a 0%, #111 60%);
    overflow: hidden;
    min-height: 420px;
    display: flex;
    align-items: center;
  }

  .hero-bg-pattern {
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 40px,
      rgba(255,214,0,.03) 40px,
      rgba(255,214,0,.03) 80px
    );
  }

  .hero-accent {
    position: absolute;
    right: -40px; top: -60px;
    width: 520px; height: 520px;
    background: radial-gradient(circle, rgba(255,214,0,.12) 0%, transparent 70%);
    border-radius: 50%;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 60px 48px;
    max-width: 620px;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,214,0,.15);
    border: 1px solid rgba(255,214,0,.4);
    color: var(--amarelo);
    font-size: .75rem;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 30px;
    margin-bottom: 20px;
  }
  .hero-tag::before {
    content: '';
    width: 7px; height: 7px;
    background: var(--amarelo);
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }
  @keyframes pulse {
    0%,100%{opacity:1;transform:scale(1)}
    50%{opacity:.5;transform:scale(1.4)}
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    line-height: 1.05;
    color: var(--branco);
    margin-bottom: 8px;
  }
  .hero h1 span { color: var(--amarelo); }

  .hero p {
    font-size: 1.05rem;
    color: #bbb;
    margin: 16px 0 28px;
    line-height: 1.65;
    max-width: 480px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--amarelo);
    color: var(--preto);
    padding: 16px 36px;
    border-radius: 50px;
    font-weight: 900;
    font-size: 1.05rem;
    text-decoration: none;
    transition: transform .2s, box-shadow .2s;
    box-shadow: 0 4px 20px rgba(255,214,0,.3);
  }
  .hero-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(255,214,0,.4);
  }
  .hero-cta svg { flex-shrink: 0; }

  /* ── PROMO STRIP ── */
  .promo-strip {
    background: var(--amarelo);
    display: flex;
    gap: 1px;
    overflow: hidden;
  }

  .promo-card {
    flex: 1;
    background: var(--preto);
    text-align: center;
    padding: 22px 16px;
    transition: background .25s;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  .promo-card:hover { background: #1e1e1e; }
  .promo-card:hover .promo-price { color: var(--amarelo); }

  .promo-label {
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 4px;
  }
  .promo-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    color: var(--branco);
    letter-spacing: 1px;
    transition: color .25s;
  }
  .promo-price span { font-size: 1rem; }

  /* ── SECTION ── */
  section { padding: 60px 32px; }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 2px;
    margin-bottom: 8px;
    color: var(--branco);
  }
  .section-title span { color: var(--amarelo); }
  .section-sub {
    font-size: .88rem;
    color: #777;
    margin-bottom: 32px;
  }

  /* ── PRODUCT GRID ── */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
  }

  .product-card {
    background: var(--cinza-escuro);
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    overflow: hidden;
    transition: transform .2s, border-color .2s;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .product-card:hover {
    transform: translateY(-6px);
    border-color: var(--amarelo);
  }

  .product-img {
    width: 100%;
    aspect-ratio: 1;
    background: #252525;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    position: relative;
    overflow: hidden;
  }
  .product-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,.5));
  }

  .product-badge {
    position: absolute;
    top: 12px; left: 12px;
    background: var(--amarelo);
    color: var(--preto);
    font-size: .65rem;
    font-weight: 900;
    padding: 3px 8px;
    border-radius: 6px;
    letter-spacing: .5px;
    z-index: 2;
  }

  .product-info {
    padding: 16px;
  }
  .product-brand {
    font-size: .7rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--amarelo);
    margin-bottom: 4px;
  }
  .product-name {
    font-size: .9rem;
    font-weight: 700;
    color: var(--branco);
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .product-price-old {
    font-size: .75rem;
    color: #555;
    text-decoration: line-through;
    margin-bottom: 2px;
  }
  .product-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: var(--amarelo);
    letter-spacing: 1px;
  }
  .product-price small {
    font-family: 'Nunito', sans-serif;
    font-size: .7rem;
    color: #888;
    font-weight: 600;
    letter-spacing: 0;
  }

  .btn-comprar {
    display: block;
    background: var(--amarelo);
    color: var(--preto);
    text-align: center;
    padding: 12px;
    font-weight: 900;
    font-size: .88rem;
    border-radius: 10px;
    margin-top: 12px;
    transition: opacity .2s;
    text-decoration: none;
  }
  .btn-comprar:hover { opacity: .85; }

  /* ── CATEGORIES ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 14px;
  }

  .cat-card {
    background: var(--cinza-escuro);
    border: 1px solid #2a2a2a;
    border-radius: 14px;
    padding: 24px 16px;
    text-align: center;
    cursor: pointer;
    transition: all .22s;
    text-decoration: none;
    display: block;
    color: inherit;
  }
  .cat-card:hover {
    background: var(--amarelo);
    border-color: var(--amarelo);
    transform: translateY(-4px);
  }
  .cat-card:hover .cat-icon { filter: none; }
  .cat-card:hover .cat-name { color: var(--preto); }

  .cat-icon {
    font-size: 2.2rem;
    margin-bottom: 8px;
    display: block;
    filter: grayscale(30%);
  }
  .cat-name {
    font-size: .8rem;
    font-weight: 800;
    letter-spacing: .5px;
    color: var(--branco);
    text-transform: uppercase;
    transition: color .22s;
  }

  /* ── TRUST BAR ── */
  .trust-bar {
    background: var(--cinza-escuro);
    border-top: 1px solid #222;
    border-bottom: 1px solid #222;
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 0;
    padding: 0;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 24px 20px;
    flex: 1;
    min-width: 180px;
    border-right: 1px solid #222;
  }
  .trust-item:last-child { border-right: none; }
  .trust-icon {
    font-size: 1.8rem;
    flex-shrink: 0;
  }
  .trust-text strong {
    display: block;
    font-size: .88rem;
    font-weight: 800;
    color: var(--branco);
    margin-bottom: 2px;
  }
  .trust-text span {
    font-size: .75rem;
    color: #666;
  }

  /* ── FOOTER ── */
  footer {
    background: #0a0a0a;
    border-top: 1px solid #1f1f1f;
    padding: 40px 32px 28px;
    text-align: center;
  }
  .footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    color: var(--amarelo);
    letter-spacing: 3px;
    margin-bottom: 8px;
  }
  .footer-disclaimer {
    font-size: .75rem;
    color: #444;
    max-width: 600px;
    margin: 0 auto 20px;
    line-height: 1.7;
  }
  .footer-disclaimer a {
    color: var(--amarelo);
    text-decoration: none;
  }
  footer hr { border-color: #1a1a1a; margin: 20px 0; }
  footer p { font-size: .72rem; color: #333; }

  /* ── FLOATING CTA ── */
  .float-cta {
    position: fixed;
    bottom: 24px; right: 24px;
    background: var(--amarelo);
    color: var(--preto);
    border-radius: 50px;
    padding: 14px 24px;
    font-weight: 900;
    font-size: .9rem;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(255,214,0,.35);
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 200;
    animation: bounceIn .6s .5s cubic-bezier(.22,1,.36,1) both;
    transition: transform .2s;
  }
  .float-cta:hover { transform: scale(1.06); }
  @keyframes bounceIn {
    from{transform:translateY(80px);opacity:0}
    to{transform:translateY(0);opacity:1}
  }

  /* responsive */
  @media(max-width:600px) {
    .hero-content { padding: 48px 24px; }
    .promo-strip { flex-direction: column; gap: 1px; }
    .trust-item { border-right: none; border-bottom: 1px solid #222; }
    section { padding: 48px 20px; }
    .hero h1 { font-size: 2.6rem; }
  }
</style>
</head>
